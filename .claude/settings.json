{
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git rm *)",
      "Bash(git merge *)",
      "Bash(git reset *)",
      "Bash(git stash *)",
      "Bash(gh pr *)",
      "Bash(pnpm --filter @gammaray/api lint)",
      "Bash(pnpm --filter @gammaray/example lint)",
      "Bash(pnpm --filter @gammaray/music lint)",
      "Bash(pnpm --filter @gammaray/ui lint)",
      "Bash(docker context ls)",
      "Bash(docker compose ps)",
      "Bash(docker compose ps *)",
      "Bash(docker compose logs)",
      "Bash(docker compose logs *)",
      "mcp__claude-in-chrome__tabs_context_mcp",
      "mcp__claude-in-chrome__read_console_messages",
      "ToolSearch",
      "LSP"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(docker system prune*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/**)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "failIfUnavailable": false,
    "allowUnsandboxedCommands": true,
    "excludedCommands": ["docker *", "colima *"],
    "network": {
      "allowLocalBinding": true,
      "allowedDomains": ["localhost", "github.com", "api.github.com"],
      "allowAllUnixSockets": true,
      "enableWeakerNetworkIsolation": true
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/auto-approve-bash.sh"
          }
        ]
      }
    ]
  }
}
