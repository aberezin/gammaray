{
  "name": "@gammaray/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "lint": "tsc --noEmit",
    "test": "jest",
    "db:migrate": "pnpm --filter @gammaray/database db:migrate",
    "db:seed": "ts-node -r tsconfig-paths/register src/seed/seed.ts",
    "db:epoch:bump": "ts-node -r tsconfig-paths/register src/meta/epoch-bump.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "@gammaray/auth": "workspace:*",
    "@gammaray/core": "workspace:*",
    "@gammaray/notesync-schema": "workspace:*",
    "@gammaray/music-schema": "workspace:*",
    "@gammaray/database": "workspace:*",
    "@nestjs/apollo": "^12.2.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/graphql": "^12.2.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^10.4.0",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.4.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.0",
    "graphql": "^16.9.0",
    "graphql-subscriptions": "^2.0.0",
    "graphql-type-json": "^0.3.2",
    "graphql-ws": "^5.16.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/jest": "^29.5.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/ws": "^8.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "*"
  }
}
